# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local

# ── Project-specific ignores ────────────────────────────────────────────────

# Temporary / development reference files (data already extracted to JSON)
/temp_images/
/kyungsung-curriculum-2025.pdf/

# Shadow / duplicate app subtree (legacy migration artifact)
/app/app/

# Backup route files
**/*.route.bak
**/*.bak

# Claude Code local IDE settings (machine-specific)
.claude/settings.local.json
**/.claude/settings.local.json

# Claude Code skill definition files (project-local, not for deployment)
*.SKILL.md
